      const esc = (v: string) => /[",\n]/.test(v) ? `"${v.replace(/"/g, '""')}"` : v;
      return [typeLabel, esc(r.category), r.amount.toFixed(2), esc(r.handler || ''), esc(r.notes || ''), r.record_date].join(', ');
